# Claude API 키 (필수)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# 서버 포트 (기본값: 4000)
PORT=4000

# DB 파일 경로 (기본값: ./blog.db)
DB_PATH=./blog.db

# 사용할 Claude 모델 (기본값: claude-sonnet-4-6)
# 선택지: claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5-20251001
MODEL=claude-sonnet-4-6
